{
  "meta": {
    "name": "Sleep Sheep UI Kit",
    "version": "1.0.0",
    "source": "websleepsheep/styles/globals.css"
  },
  "color": {
    "bg": {
      "deep": "#0b091a",
      "surface": "#13102a",
      "card": "#1c1838"
    },
    "accent": {
      "core": "#6b6bb5",
      "light": "#a89fe8",
      "pale": "#c4b8ff"
    },
    "text": {
      "primary": "#ede8ff",
      "secondary": "#7a7290"
    },
    "border": {
      "subtle": "rgba(168, 159, 232, 0.15)"
    },
    "gradient": {
      "cta": "linear-gradient(135deg, #a89fe8, #c4b8ff)",
      "headline": "linear-gradient(145deg, #ede8ff, #c4b8ff)"
    }
  },
  "typography": {
    "fontFamily": {
      "base": "Poppins, sans-serif"
    },
    "fontWeight": {
      "light": 300,
      "regular": 400
    },
    "textStyle": {
      "displayLg": {
        "fontSize": "clamp(2.2rem, 8vw, 4.2rem)",
        "lineHeight": 1.05,
        "letterSpacing": "-0.02em",
        "fontWeight": 400
      },
      "headingMd": {
        "fontSize": "clamp(1.7rem, 5.4vw, 2.8rem)",
        "lineHeight": 1.14,
        "fontWeight": 400
      },
      "headingSm": {
        "fontSize": "1.1rem",
        "lineHeight": 1.4,
        "fontWeight": 400
      },
      "body": {
        "fontSize": "16px",
        "lineHeight": "24px",
        "fontWeight": 400
      },
      "bodySmall": {
        "fontSize": "14px",
        "lineHeight": "20px",
        "fontWeight": 400
      },
      "eyebrow": {
        "fontSize": "14px",
        "lineHeight": "20px",
        "fontWeight": 300,
        "letterSpacing": "0.14em",
        "textTransform": "uppercase"
      }
    }
  },
  "radius": {
    "sm": "12px",
    "md": "14px",
    "lg": "16px",
    "xl": "20px",
    "pill": "9999px"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "2rem",
    "4xl": "2.5rem",
    "5xl": "3rem",
    "6xl": "4rem",
    "sectionY": "5.4rem"
  },
  "motion": {
    "duration": {
      "fast": "220ms",
      "medium": "260ms",
      "slow": "520ms"
    },
    "timing": {
      "standard": "ease",
      "soft": "cubic-bezier(0.22, 1, 0.36, 1)"
    }
  },
  "component": {
    "button": {
      "height": "auto",
      "paddingMobile": "0.8rem 1.15rem",
      "paddingDesktop": "0.9rem 1.4rem",
      "radius": "9999px",
      "border": "1px solid transparent"
    },
    "card": {
      "background": "#1c1838",
      "border": "1px solid rgba(168, 159, 232, 0.15)",
      "radius": "20px"
    },
    "input": {
      "minHeight": "48px",
      "padding": "0.75rem 0.9rem",
      "radius": "14px",
      "border": "1px solid rgba(168, 159, 232, 0.15)"
    },
    "navbar": {
      "height": "116px",
      "scrollThresholdPx": 120,
      "scrolledBackground": "color-mix(in srgb, #0b091a 90%, transparent)",
      "scrolledBackdropBlur": "10px"
    }
  }
}
